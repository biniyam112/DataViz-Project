      </column>
      <column caption='Fishing Hours YoY' datatype='real' name='[Calculation_1431631718912000]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1822782552768513]) - SUM([Fishing Hours Selected Year (copy)_1822782553104386]))&#13;&#10;/ ABS(SUM([Fishing Hours Selected Year (copy)_1822782553104386]))' />
      </column>
      <column caption='Hours YoY' datatype='real' name='[Calculation_1431631719366657]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Fishing Hours Selected Year (copy)_1822782911598599]) - SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;/ ABS(SUM([Fishing Hours Previous Year (copy)_1822782911533062]))' />
      </column>
      <column caption='Fleets YoY' datatype='real' name='[Calculation_1431631719510018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1822782915493899])-SUM([Calculation_1431631719911428]))/&#13;&#10;SUM([Calculation_1431631719911428])' />
      </column>
      <column caption='Fleets Previous Year' datatype='integer' name='[Calculation_1431631719911428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [year] = [Calculation_1822782553575427] - 1 THEN [mmsi_present] END' />
      </column>
      <column caption='Fishing Efficiency YoY' datatype='real' name='[Calculation_1431631720579077]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Fishing Hours Previous Year (copy)_1822782911533062]) &lt;&gt; 0 AND SUM([Fishing Hours Selected Year (copy)_1822782911598599]) &lt;&gt; 0 THEN&#13;&#10;    (&#13;&#10;        (SUM([Calculation_1822782552768513]) / SUM([Fishing Hours Selected Year (copy)_1822782911598599]))&#13;&#10;        - (SUM([Fishing Hours Selected Year (copy)_1822782553104386]) / SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;    )&#13;&#10;    / ABS(SUM([Fishing Hours Selected Year (copy)_1822782553104386]) / SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Time Filter' datatype='boolean' name='[Calculation_1431631731363846]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[year] = [Calculation_1822782553575427] AND  [month] = [Calculation_1431631732645895]' />
      </column>
      <column caption='Selected Month' datatype='integer' name='[Calculation_1431631732645895]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 4]' />
      </column>
      <column caption='Selected Flag' datatype='boolean' name='[Calculation_1431631734870024]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[flag] = [Parameters].[Parameter 5]' />
      </column>
      <column caption='Year Filter' datatype='boolean' name='[Calculation_1431631738449929]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[year] = [Calculation_1822782553575427]' />
      </column>
      <column caption='Is Unknown Flag' datatype='boolean' name='[Calculation_1431631960104970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STARTSWITH([flag], &quot;UNKNOWN&quot;) OR [flag] = &quot;UNK&quot;' />
      </column>
      <column caption='Unknown Fishing Hours' datatype='real' name='[Calculation_1431631960289291]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1431631960104970] THEN [fishing_hours] END' />
      </column>
      <column caption='Unknown Vessel Count' datatype='integer' name='[Calculation_1431631960473612]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1431631960104970] THEN [mmsi_present] END' />
      </column>
      <column caption='Flags Cleaned (for Unknown)' datatype='string' name='[Calculation_1431631961284621]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF STARTSWITH([flag], &quot;UNKNOWN&quot;) OR [flag] = &quot;UNK&quot;&#13;&#10;THEN &quot;Unknown&quot;&#13;&#10;ELSE [flag]&#13;&#10;END' />
      </column>
      <column caption='Unknown Fishing Hours Selected Year' datatype='real' name='[Calculation_1431631962066958]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ([year] = [Calculation_1822782553575427])&#13;&#10;THEN [Calculation_1431631960289291]&#13;&#10;END' />
      </column>
      <column caption='Unknown Fishing Hours Prev Year' datatype='real' name='[Calculation_1431631962517519]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [year] = [Calculation_1822782553575427]-1&#13;&#10;THEN [Calculation_1431631960289291]&#13;&#10;END' />
      </column>
      <column caption='Fishing Hours Selected Year' datatype='real' name='[Calculation_1822782552768513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]&#13;&#10;THEN [fishing_hours]&#13;&#10;END' />
      </column>
      <column caption='Selected Year' datatype='integer' name='[Calculation_1822782553575427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2]' />
      </column>
      <column caption='Previous Year' datatype='integer' name='[Calculation_1822782553681924]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2]-1' />
      </column>
      <column caption='Fishing Efficiency' datatype='real' name='[Calculation_1822782913036296]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fishing_hours])/SUM([hours])' />
      </column>
      <column caption='Fishing Efficiency Selected Year' datatype='real' name='[Calculation_1822782914228233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1822782552768513])/SUM([Fishing Hours Selected Year (copy)_1822782911598599])' />
      </column>
      <column caption='Fleets Selected Year' datatype='integer' name='[Calculation_1822782915493899]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [year] = [Calculation_1822782553575427] THEN [mmsi_present] END' />
      </column>
      <column caption='Impact Category' datatype='string' name='[Calculation_3060282856341504]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [geartype]&#13;&#10;    WHEN &quot;dredge_fishing&quot; THEN &quot;High Benthic Habitat&quot;&#13;&#10;    WHEN &quot;trawlers&quot; THEN &quot;High Benthic Habitat&quot;&#13;&#10;    WHEN &quot;drifting_longlines&quot; THEN &quot;High Bycatch&quot;&#13;&#10;    WHEN &quot;set_longlines&quot; THEN &quot;High Bycatch&quot;&#13;&#10;    WHEN &quot;set_gillnets&quot; THEN &quot;High Bycatch&quot;&#13;&#10;    WHEN &quot;purse_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;tuna_purse_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;other_purse_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;other_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;seiners&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;pole_and_line&quot; THEN &quot;Low Impact&quot;&#13;&#10;    WHEN &quot;trollers&quot; THEN &quot;Low Impact&quot;&#13;&#10;    WHEN &quot;pots_and_traps&quot; THEN &quot;Moderate Traps&quot;&#13;&#10;    WHEN &quot;squid_jigger&quot; THEN &quot;Specialized&quot;&#13;&#10;    WHEN &quot;fishing&quot; THEN &quot;Unspecified&quot;&#13;&#10;    WHEN &quot;fixed_gear&quot; THEN &quot;Unspecified&quot;&#13;&#10;    ELSE &quot;Unspecified&quot;   // safety net for any new gear types&#13;&#10;END' />
      </column>
      <column caption='Fishing Efficiency Previous Year' datatype='real' name='[Fishing Efficiency Selected Year (copy)_1822782914465802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fishing Hours Selected Year (copy)_1822782553104386])/SUM([Fishing Hours Previous Year (copy)_1822782911533062])' />
      </column>
      <column caption='Hours Previous Year' datatype='real' name='[Fishing Hours Previous Year (copy)_1822782911533062]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]-1&#13;&#10;THEN [hours]&#13;&#10;END' />
      </column>
      <column caption='Fishing Hours Previous Year' datatype='real' name='[Fishing Hours Selected Year (copy)_1822782553104386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]-1&#13;&#10;THEN [fishing_hours]&#13;&#10;END' />
      </column>
      <column caption='Hours Selected Year' datatype='real' name='[Fishing Hours Selected Year (copy)_1822782911598599]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]&#13;&#10;THEN [hours]&#13;&#10;END' />
      </column>
