            <column caption='Impact Category1' datatype='string' name='[impact_category]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1431631738449929]' derivation='None' name='[none:Calculation_1431631738449929:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_3060282856341504]' derivation='None' name='[none:Calculation_3060282856341504:nk]' pivot='key' type='nominal' />
            <column-instance column='[cell_ll_lon]' derivation='None' name='[none:cell_ll_lon:qk]' pivot='key' type='quantitative' />
            <column-instance column='[flag]' derivation='None' name='[none:flag:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1822782552768513]' derivation='Sum' name='[sum:Calculation_1822782552768513:qk]' pivot='key' type='quantitative' />
            <column-instance column='[fishing_hours]' derivation='Sum' name='[sum:fishing_hours:qk]' pivot='key' type='quantitative' />
            <column-instance column='[date]' derivation='Month-Trunc' name='[tmn:date:ok]' pivot='key' type='ordinal' />
            <column caption='Year' datatype='integer' name='[year]' role='dimension' type='quantitative' />
          </datasource-dependencies>
