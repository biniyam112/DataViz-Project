            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.08o8pcx0edzbjh1cnwrze1bvnlik'>
            <column caption='Fishing Efficiency YoY' datatype='real' name='[Calculation_1431631720579077]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Fishing Hours Previous Year (copy)_1822782911533062]) &lt;&gt; 0 AND SUM([Fishing Hours Selected Year (copy)_1822782911598599]) &lt;&gt; 0 THEN&#13;&#10;    (&#13;&#10;        (SUM([Calculation_1822782552768513]) / SUM([Fishing Hours Selected Year (copy)_1822782911598599]))&#13;&#10;        - (SUM([Fishing Hours Selected Year (copy)_1822782553104386]) / SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;    )&#13;&#10;    / ABS(SUM([Fishing Hours Selected Year (copy)_1822782553104386]) / SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;ELSE NULL&#13;&#10;END' />
            </column>
            <column caption='Is Unknown Flag' datatype='boolean' name='[Calculation_1431631960104970]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='STARTSWITH([flag], &quot;UNKNOWN&quot;) OR [flag] = &quot;UNK&quot;' />
            </column>
            <column caption='Fishing Hours Selected Year' datatype='real' name='[Calculation_1822782552768513]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]&#13;&#10;THEN [fishing_hours]&#13;&#10;END' />
            </column>
            <column caption='Fishing Efficiency Selected Year' datatype='real' name='[Calculation_1822782914228233]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1822782552768513])/SUM([Fishing Hours Selected Year (copy)_1822782911598599])' />
            </column>
            <column caption='Fishing Efficiency Previous Year' datatype='real' name='[Fishing Efficiency Selected Year (copy)_1822782914465802]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Fishing Hours Selected Year (copy)_1822782553104386])/SUM([Fishing Hours Previous Year (copy)_1822782911533062])' />
            </column>
            <column caption='Hours Previous Year' datatype='real' name='[Fishing Hours Previous Year (copy)_1822782911533062]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]-1&#13;&#10;THEN [hours]&#13;&#10;END' />
            </column>
            <column caption='Fishing Hours Previous Year' datatype='real' name='[Fishing Hours Selected Year (copy)_1822782553104386]' role='measure' type='quantitative'>
