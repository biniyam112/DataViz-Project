      <column caption='Unknown Fishing Hours' datatype='real' name='[Calculation_1431631960289291]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1431631960104970] THEN [fishing_hours] END' />
      </column>
      <column caption='Unknown Vessel Count' datatype='integer' name='[Calculation_1431631960473612]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1431631960104970] THEN [mmsi_present] END' />
