      <column caption='Unknown Fishing Hours Prev Year' datatype='real' name='[Calculation_1431631962517519]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [year] = [Calculation_1822782553575427]-1&#13;&#10;THEN [Calculation_1431631960289291]&#13;&#10;END' />
