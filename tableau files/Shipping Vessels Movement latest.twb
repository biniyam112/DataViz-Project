      <column caption='Flags Cleaned (for Unknown)' datatype='string' name='[Calculation_1431631961284621]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF STARTSWITH([flag], &quot;UNKNOWN&quot;) OR [flag] = &quot;UNK&quot;&#13;&#10;THEN &quot;Unknown&quot;&#13;&#10;ELSE [flag]&#13;&#10;END' />
      </column>
      <column caption='Unknown Fishing Hours Selected Year' datatype='real' name='[Calculation_1431631962066958]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ([year] = [Calculation_1822782553575427])&#13;&#10;THEN [Calculation_1431631960289291]&#13;&#10;END' />
