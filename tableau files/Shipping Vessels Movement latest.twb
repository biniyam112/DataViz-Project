      <column caption='Fishing Hours YoY' datatype='real' name='[Calculation_1431631718912000]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1822782552768513]) - SUM([Fishing Hours Selected Year (copy)_1822782553104386]))&#13;&#10;/ ABS(SUM([Fishing Hours Selected Year (copy)_1822782553104386]))' />
      </column>
      <column caption='Hours YoY' datatype='real' name='[Calculation_1431631719366657]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Fishing Hours Selected Year (copy)_1822782911598599]) - SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;/ ABS(SUM([Fishing Hours Previous Year (copy)_1822782911533062]))' />
      </column>
      <column caption='Fleets YoY' datatype='real' name='[Calculation_1431631719510018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1822782915493899])-SUM([Calculation_1431631719911428]))/&#13;&#10;SUM([Calculation_1431631719911428])' />
      </column>
      <column caption='Fleets Previous Year' datatype='integer' name='[Calculation_1431631719911428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [year] = [Calculation_1822782553575427] - 1 THEN [mmsi_present] END' />
      </column>
      <column caption='Fishing Efficiency YoY' datatype='real' name='[Calculation_1431631720579077]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Fishing Hours Previous Year (copy)_1822782911533062]) &lt;&gt; 0 AND SUM([Fishing Hours Selected Year (copy)_1822782911598599]) &lt;&gt; 0 THEN&#13;&#10;    (&#13;&#10;        (SUM([Calculation_1822782552768513]) / SUM([Fishing Hours Selected Year (copy)_1822782911598599]))&#13;&#10;        - (SUM([Fishing Hours Selected Year (copy)_1822782553104386]) / SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;    )&#13;&#10;    / ABS(SUM([Fishing Hours Selected Year (copy)_1822782553104386]) / SUM([Fishing Hours Previous Year (copy)_1822782911533062]))&#13;&#10;ELSE NULL&#13;&#10;END' />
      </column>
      <column caption='Time Filter' datatype='boolean' name='[Calculation_1431631731363846]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[year] = [Calculation_1822782553575427] AND  [month] = [Calculation_1431631732645895]' />
