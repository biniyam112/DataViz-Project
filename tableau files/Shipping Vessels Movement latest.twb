      <column caption='Is Unknown Flag' datatype='boolean' name='[Calculation_1431631960104970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STARTSWITH([flag], &quot;UNKNOWN&quot;) OR [flag] = &quot;UNK&quot;' />
