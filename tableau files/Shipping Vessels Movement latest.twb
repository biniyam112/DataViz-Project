    <worksheet name='Map Fishing Activity by Country'>
      <table>
        <view>
          <datasources>
            <datasource caption='fleet_monthly (fleet_data)' name='federated.08o8pcx0edzbjh1cnwrze1bvnlik' />
            <datasource name='Parameters' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Top n Flags by Fishing Hours' datatype='integer' default-format='N' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='20'>
              <calculation class='tableau' formula='20' />
              <range granularity='1' max='20' min='1' />
            </column>
            <column caption='Selected Year' datatype='integer' default-format='n0;-0' name='[Parameter 2]' param-domain-type='list' role='measure' type='quantitative' value='2022'>
              <calculation class='tableau' formula='2022' />
            </column>
            <column caption='Selected Month' datatype='integer' name='[Parameter 4]' param-domain-type='list' role='measure' type='quantitative' value='11'>
              <calculation class='tableau' formula='11' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.08o8pcx0edzbjh1cnwrze1bvnlik'>
            <column caption='Selected Month' datatype='integer' name='[Calculation_1431631732645895]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 4]' />
            </column>
            <column caption='Year Filter' datatype='boolean' name='[Calculation_1431631738449929]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[year] = [Calculation_1822782553575427]' />
            </column>
            <column caption='Is Unknown Flag' datatype='boolean' name='[Calculation_1431631960104970]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='STARTSWITH([flag], &quot;UNKNOWN&quot;) OR [flag] = &quot;UNK&quot;' />
            </column>
            <column caption='Fishing Hours Selected Year' datatype='real' name='[Calculation_1822782552768513]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  YEAR([date]) = [Parameters].[Parameter 2]&#13;&#10;THEN [fishing_hours]&#13;&#10;END' />
            </column>
            <column caption='Selected Year' datatype='integer' name='[Calculation_1822782553575427]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Parameters].[Parameter 2]' />
            </column>
            <column caption='Impact Category' datatype='string' name='[Calculation_3060282856341504]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [geartype]&#13;&#10;    WHEN &quot;dredge_fishing&quot; THEN &quot;High Benthic Habitat&quot;&#13;&#10;    WHEN &quot;trawlers&quot; THEN &quot;High Benthic Habitat&quot;&#13;&#10;    WHEN &quot;drifting_longlines&quot; THEN &quot;High Bycatch&quot;&#13;&#10;    WHEN &quot;set_longlines&quot; THEN &quot;High Bycatch&quot;&#13;&#10;    WHEN &quot;set_gillnets&quot; THEN &quot;High Bycatch&quot;&#13;&#10;    WHEN &quot;purse_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;tuna_purse_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;other_purse_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;other_seines&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;seiners&quot; THEN &quot;Moderate Pelagic&quot;&#13;&#10;    WHEN &quot;pole_and_line&quot; THEN &quot;Low Impact&quot;&#13;&#10;    WHEN &quot;trollers&quot; THEN &quot;Low Impact&quot;&#13;&#10;    WHEN &quot;pots_and_traps&quot; THEN &quot;Moderate Traps&quot;&#13;&#10;    WHEN &quot;squid_jigger&quot; THEN &quot;Specialized&quot;&#13;&#10;    WHEN &quot;fishing&quot; THEN &quot;Unspecified&quot;&#13;&#10;    WHEN &quot;fixed_gear&quot; THEN &quot;Unspecified&quot;&#13;&#10;    ELSE &quot;Unspecified&quot;   // safety net for any new gear types&#13;&#10;END' />
            </column>
            <column-instance column='[Calculation_1431631732645895]' derivation='Attribute' name='[attr:Calculation_1431631732645895:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1822782552768513]' derivation='Avg' name='[avg:Calculation_1822782552768513:qk]' pivot='key' type='quantitative' />
            <column-instance column='[cell_ll_lat]' derivation='Avg' name='[avg:cell_ll_lat:qk]' pivot='key' type='quantitative' />
